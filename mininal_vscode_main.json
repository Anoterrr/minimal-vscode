{
    // ─── Interface & Visual ───
    "workbench.startupEditor": "newUntitledFile",
    "workbench.activityBar.location": "hidden",
    "workbench.editor.showTabs": "single",
    "workbench.statusBar.visible": false,
    "workbench.layoutControl.enabled": false,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "Tokyo Night",
    "editor.fontSize": 16,
    "editor.lineHeight": 1.8,
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontLigatures": true,
    "editor.minimap.enabled": false,
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "hidden",
    "editor.stickyScroll.enabled": false,
    "editor.renderLineHighlight": "gutter",
    "editor.rulers": [
        80,
        120
    ],
    "editor.guides.bracketPairs": "active",
    "editor.guides.indentation": false,
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.overviewRulerBorder": false,
    "breadcrumbs.enabled": false,
    "window.commandCenter": false,
    "window.titleBarStyle": "native",
    "window.title": "${rootName}${separator}${activeEditorShort}",
    // ─── Editor Behavior ───
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    "editor.trimAutoWhitespace": true,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.wordWrap": "off",
    "editor.linkedEditing": true,
    "editor.suggest.preview": true,
    "editor.suggest.showStatusBar": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.parameterHints.enabled": false,
    "editor.hover.delay": 600,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.tabCompletion": "on",
    "editor.snippetSuggestions": "top",
    // ─── Vim (VSCodeVim) ───
    // "vim.enable": true,
    // "vim.leader": "<space>",
    // "vim.useSystemClipboard": true,
    // "vim.hlsearch": true,
    // "vim.incsearch": true,
    // "vim.smartcase": true,
    // "vim.ignorecase": true,
    // "vim.showcmd": true,
    // "vim.easymotion": true,
    // "vim.sneak": true,
    // "vim.surround": true,
    // "vim.normalModeKeyBindingsNonRecursive": [
    //   // File tree toggle (mirrors <leader>e in LazyVim)
    //   { "before": ["<leader>", "e"], "commands": ["workbench.action.toggleSidebarVisibility"] },
    //   // Buffer management
    //   { "before": ["<leader>", "b", "d"], "commands": ["workbench.action.closeActiveEditor"] },
    //   { "before": ["<leader>", "b", "o"], "commands": ["workbench.action.closeOtherEditors"] },
    //   // Fuzzy find (mirrors <leader>ff, <leader>fg)
    //   { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"] },
    //   { "before": ["<leader>", "f", "g"], "commands": ["workbench.action.findInFiles"] },
    //   { "before": ["<leader>", "f", "r"], "commands": ["workbench.action.openRecent"] },
    //   // LSP (mirrors LazyVim defaults)
    //   { "before": ["g", "d"], "commands": ["editor.action.revealDefinition"] },
    //   { "before": ["g", "r"], "commands": ["editor.action.goToReferences"] },
    //   { "before": ["g", "i"], "commands": ["editor.action.goToImplementation"] },
    //   { "before": ["g", "h"], "commands": ["editor.action.showDefinitionPreviewHover"] },
    //   { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"] },
    //   { "before": ["<leader>", "c", "r"], "commands": ["editor.action.rename"] },
    //   { "before": ["<leader>", "c", "d"], "commands": ["workbench.actions.view.problems"] },
    //   // Diagnostics navigation
    //   { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },
    //   { "before": ["[", "d"], "commands": ["editor.action.marker.prev"] },
    //   // Terminal toggle
    //   { "before": ["<leader>", "t", "t"], "commands": ["workbench.action.terminal.toggleTerminal"] },
    //   // Format
    //   { "before": ["<leader>", "m", "f"], "commands": ["editor.action.formatDocument"] },
    //   // Clear search highlight
    //   { "before": ["<leader>", "h"], "commands": [":nohlsearch"] }
