# zen-dots — gitconfig
# Aplica: cp ~/dotfiles/config/gitconfig ~/.gitconfig

[core]
	pager = delta

[delta]
	navigate        = true
	dark            = true
	syntax-theme    = tokyonight_night
	line-numbers    = true
	side-by-side    = false

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[init]
	defaultBranch = main

[pull]
	rebase = true
